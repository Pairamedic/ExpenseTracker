rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's private data — only the owner can read/write
    match /users/{userId}/{rest=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared view snapshots — anyone can read, only authenticated users can write
    // The token in the URL is the only "secret" — keep share tokens private
    match /shared/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
